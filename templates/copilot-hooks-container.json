{
  "hooks": {
    "UserPromptSubmit": [
      {
        "command": "python3 {{SHIM}} userpromptsubmit",
        "type": "command",
        "timeout": 30
      }
    ],
    "Stop": [
      {
        "command": "python3 {{SHIM}} stop",
        "type": "command",
        "timeout": 60
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit",
        "command": "python3 {{SHIM}} pretool",
        "type": "command",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "command": "python3 {{SHIM}} posttool",
        "type": "command",
        "timeout": 5
      }
    ]
  }
}
