{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{VENV_PYTHON}} {{ENGRAM_HOME}}/hooks/prompt_hook.py",
            "timeout": 30,
            "statusMessage": "Retrieving context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{VENV_PYTHON}} {{ENGRAM_HOME}}/hooks/stop_hook.py",
            "timeout": 60,
            "statusMessage": "Thinking..."
          }
        ]
      }
    ]
  }
}
